# ==============================================================================
# Environment variable template.
#
# Copy this file to `.env` and fill in the real values for your local setup.
# The `.env` file is ignored by Git — never commit it.
# ==============================================================================

# -----------------------------------------------------------------------------
# Meta / WhatsApp Cloud API credentials
# -----------------------------------------------------------------------------

# The Meta phone number ID of your TEST business phone number.
# Find it on Meta for Developers → your app → WhatsApp → API Setup.
# Looks like a long integer: 123456789012345
WHATSAPP_PHONE_NUMBER_ID=

# Your WhatsApp Business Account (WABA) ID.
# Find it on the same API Setup page.
WHATSAPP_BUSINESS_ACCOUNT_ID=

# Access token for calling Meta's Graph API.
# Temporary tokens (24h) are fine for development. For any deployment that
# lives more than a day, use a long-lived System User token.
WHATSAPP_ACCESS_TOKEN=

# Graph API version — pin an explicit version so Meta upgrades don't break us.
WHATSAPP_GRAPH_API_VERSION=v23.0

# The app secret from Meta → Settings → Basic → App Secret.
# Used to verify the X-Hub-Signature-256 header on incoming webhooks.
WHATSAPP_APP_SECRET=

# An arbitrary string you invent. At least 20 chars, ideally random.
# You give this same string to Meta when registering the webhook URL;
# it is used during the initial GET verification handshake.
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# -----------------------------------------------------------------------------
# Application configuration
# -----------------------------------------------------------------------------

# Which pre-approved template to send in campaigns.
# The test account ships with `hello_world` (language: en_US) already approved.
CAMPAIGN_TEMPLATE_NAME=hello_world
CAMPAIGN_TEMPLATE_LANGUAGE=en_US

# Path to the SQLite database file. Relative paths are resolved against the
# project root. For production with Postgres this would be a full URL.
DATABASE_URL=sqlite:///./app.db

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Port the FastAPI app listens on in local development.
PORT=8000
